generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(cuid())
  clerkId   String   @unique
  email     String   @unique
  phoneNumber String?
  name      String?
  createdAt DateTime @default(now())
  applications Application[]
  gmailConnection GmailConnection?
}

model GmailConnection {
  id           String   @id @default(cuid())
  clerkId      String   @unique
  userId       String   @unique
  user         User     @relation(fields: [userId], references: [id])
  email        String
  accessToken  String
  refreshToken String?
  expiresAt    DateTime?
  historyId    String?
  nextPageToken String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model Application {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id])
  company     String
  role        String?
  stage       String   @default("Applied")
  urgency     String   @default("LOW")
  deadline    DateTime?
  deadlineText String?
  actionRequired Boolean @default(false)
  actionDescription String?
  contactEmail String?
  importantLinks Json?
  confidence  Int      @default(0)
  summary     String?
  emailId     String?
  fromEmail    String?
  subject      String?
  receivedAt   DateTime?
  isRead      Boolean  @default(false)
  isForgotten Boolean  @default(false)
  rawEmail    String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([userId, emailId])
}
